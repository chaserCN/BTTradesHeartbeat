TELEGRAM_BOT_TOKEN=123456:telegram-bot-token
TELEGRAM_CHAT_ID=123456789

# What to monitor. Defaults match the production feed and the app's Kraken pair.
FEED_URL=ws://feed.bitcoinstat.org:9000
FEED_CHANNEL=trade.btc_usd_kraken
KRAKEN_URL=wss://ws.kraken.com/v2
KRAKEN_SYMBOL=BTC/USD

# How often to probe and how long each probe listens.
PROBE_INTERVAL_MINUTES=60
PROBE_WINDOW_SECONDS=90
# If the market is too quiet to judge, the probe extends up to this window.
PROBE_MAX_WINDOW_SECONDS=180
CONNECT_TIMEOUT_SECONDS=15
# A first bad probe is re-checked after this pause before alerting the chat.
CONFIRM_DELAY_SECONDS=120

# Probes run around the clock; quiet hours only mute notifications.
QUIET_HOURS_TIME_ZONE=Europe/Kyiv
QUIET_HOURS_START=23:00
QUIET_HOURS_END=09:00

TELEGRAM_COMMAND_POLL_SECONDS=5

# Railway volume example: STATE_DIR=/data
# If STATE_DIR is not set, Railway's RAILWAY_VOLUME_MOUNT_PATH is used automatically.
STATE_DIR=.

# Local testing: RUN_ONCE=true runs one probe and exits; DRY_RUN=true prints
# Telegram messages to the console instead of sending them.
# RUN_ONCE=true
# DRY_RUN=true
